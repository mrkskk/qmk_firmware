

// clang-format on

// KO(pipe, MOD_MASK_ALT, KC_I, PIPE) // For Mac behavior on windows
//  For mac behavior on windows
// KO(slsh_ques, MOD_MASK_ALT, SLSH, BSLSH) // For Mac behavior on windows

// Disable "rotate screen" shortcut on windows (accidentally pressing this is so annoying). Assigning it to move arrows
// Only trigger when Ctrl+Alt are held without Shift/GUI, so MEH/HYPER/CAG arrows are unaffected.
KO_NEG(unrotate_down, MOD_MASK_CA, MOD_MASK_SG, KC_DOWN, C(KC_DOWN))
KO_NEG(unrotate_up, MOD_MASK_CA, MOD_MASK_SG, KC_UP, C(KC_UP))
KO_NEG(unrotate_left, MOD_MASK_CA, MOD_MASK_SG, KC_LEFT, C(KC_LEFT))
KO_NEG(unrotate_right, MOD_MASK_CA, MOD_MASK_SG, KC_RIGHT, C(KC_RIGHT))

KO(quot_dquot, MOD_MASK_SHIFT, QUOT, DQUO)    // Shifted single quote is double quote
KO(bspc_del, MOD_MASK_SHIFT, KC_BSPC, KC_DEL) // Shifted backspace is delete
