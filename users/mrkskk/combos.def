//   name     			 result    		 	  chord keys
// Layers

// clang-format off

// MODS


//Alphas
COMB(Q_COMB,            KC_Q,             KC_G,    KC_M)


//SYMBOLS

COMB(LBRC_COMB,         LBRC,             KC_C,    KC_G)
COMB(RBRC_COMB,         RBRC,             KC_K,    DK_OE)
COMB(HASH_COMB,         HASH,             KC_U, KC_K)
COMB(HAT_COMB,          HAT,               KC_W, KC_C)
COMB(DQUO_COMB,         DQUO,             QUOT, NUM_SPC)

COMB(LPRN_COMB2,         LPRN,             HM_LCTL, HM_LALT)
COMB(RPRN_COMB2,         RPRN,             HM_RALT, HM_RCTL)

//COMB(ACUTE_COMB2,        ACUTE,            HM_RGUI, KC_K)

COMB(LCB_COMB2,          LCB,              MEH_B,       HYP_L)
COMB(RCB_COMB2,          RCB,              HYP_COM,    MEH_DOT)
COMB(UNDS_COMB2,         UNDSC,            HM_RGUI,    HM_RCTL)
COMB(MINUS_COMB2,        MINUS,            HM_LCTL,    HM_LGUI)

COMB(EXLM_COMB,        EXLM,             HYP_L,     CAG_D)
COMB(PLUS_COMB,        PLUS,             HYP_L,     HM_LGUI)
COMB(PLUS_COMB2,       PLUS,             HYP_L,     HM_LCTL)
COMB(ASTR_COMB,        ASTR,              HM_LCTL, CAG_D)

COMB(SLSH_COMB2,         SLSH,             HM_LCTL,    KC_M)
COMB(BSLH_COMB2,         BSLSH,            KC_G,       HM_LGUI)

COMB(AT_COMB2,           AT,               HM_LALT,    HM_LGUI)
COMB(USD_COMB2,          USD,              HM_RGUI,    HM_RALT)
COMB(QUES_COMB2,         QUES,             CAG_P,      HYP_COM)


//Strings
COMB(COMBO_SCRT_1,       KC_SECRET_1,       KC_U, KC_K, DK_OE, DK_AA)

// Custom combos
COMB(ENT_COMBO,         KC_ENT,            KC_C, KC_G, KC_M) // Left hand, no pinky
COMB(BSPC_COMBO,        KC_BSPC,           MEH_B, HYP_L, CAG_D) // Left hand, no pinky
COMB(COMBO_CAPITALIZE,  CW_TOGG,           HM_LCTL, HM_LALT, HM_LGUI) // Caps word
//COMB(COMBO_MOUSE,       TG_MS,            MO(NAV_MAC), HM_LCTL) // Caps word


COMB(COMBO_SCRT_2,       KC_SECRET_2,         CAG_P, HYP_COM, MEH_DOT, DK_AE)
COMB(COMBO_SCRT_3,       LOGIN,            HM_RGUI, HM_RALT, HM_RCTL, HM_RSFT)
COMB(COMBO_WM,          WORK_MAIL,         HM_LGUI, HM_LALT, HM_LCTL, HM_LSFT)
COMB(COMBO_PM,          PERS_MAIL,        FN_V, MEH_B, HYP_L, CAG_D)



COMB(COMB_1,            KC_1,          NUM_SPC, CAG_P)
COMB(COMB_2,            KC_2,          NUM_SPC, HYP_COM)
COMB(COMB_3,            KC_3,          NUM_SPC, MEH_DOT)
COMB(COMB_4,            KC_4,          NUM_SPC, HM_RGUI)
COMB(COMB_5,            KC_5,          NUM_SPC, HM_RCTL)
COMB(COMB_6,            KC_6,          NUM_SPC, HM_RALT)
COMB(COMB_7,            KC_7,          NUM_SPC, KC_U)
COMB(COMB_8,            KC_8,          NUM_SPC, KC_K)
COMB(COMB_9,            KC_9,          NUM_SPC, DK_OE)
COMB(COMB_0,            KC_0,          NUM_SPC, KC_N)
//COMB(COMB_PANIC,      CLEAS,        NUM_SPC, KC_BSPC)

// clang-format off
// Accent+vowel combos (base layer only, COMBO_ONLY_FROM_LAYER 0)
// accent keys on base: KC_W(^), KC_C(¨), KC_G(`), KC_M(´), KC_J(~)
// vowels on base: HM_RSFT(A), HM_RCTL(E), HM_RGUI(I), HM_RALT(O), KC_U, KC_Y, DK_AE(Æ), DK_OE(Ø), DK_AA(Å)

// HAT (^) + vowels
COMB(CMB_HAT_A, ACCENT_COMBO(0, 0), KC_W, HM_RSFT)
COMB(CMB_HAT_E, ACCENT_COMBO(0, 1), KC_W, HM_RCTL)
COMB(CMB_HAT_I, ACCENT_COMBO(0, 2), KC_W, HM_RGUI)
COMB(CMB_HAT_O, ACCENT_COMBO(0, 3), KC_W, HM_RALT)
COMB(CMB_HAT_U, ACCENT_COMBO(0, 4), KC_W, KC_U)
COMB(CMB_HAT_Y, ACCENT_COMBO(0, 5), KC_W, KC_Y)
COMB(CMB_HAT_AE, ACCENT_COMBO(0, 6), KC_W, DK_AE)
COMB(CMB_HAT_OE, ACCENT_COMBO(0, 7), KC_W, DK_OE)
COMB(CMB_HAT_AA, ACCENT_COMBO(0, 8), KC_W, DK_AA)

// DIAE (¨) + vowels
COMB(CMB_DIAE_A, ACCENT_COMBO(1, 0), KC_C, HM_RSFT)
COMB(CMB_DIAE_E, ACCENT_COMBO(1, 1), KC_C, HM_RCTL)
COMB(CMB_DIAE_I, ACCENT_COMBO(1, 2), KC_C, HM_RGUI)
COMB(CMB_DIAE_O, ACCENT_COMBO(1, 3), KC_C, HM_RALT)
COMB(CMB_DIAE_U, ACCENT_COMBO(1, 4), KC_C, KC_U)
COMB(CMB_DIAE_Y, ACCENT_COMBO(1, 5), KC_C, KC_Y)
COMB(CMB_DIAE_AE, ACCENT_COMBO(1, 6), KC_C, DK_AE)
COMB(CMB_DIAE_OE, ACCENT_COMBO(1, 7), KC_C, DK_OE)
COMB(CMB_DIAE_AA, ACCENT_COMBO(1, 8), KC_C, DK_AA)

// GRAVE (`) + vowels
COMB(CMB_GRAVE_A, ACCENT_COMBO(2, 0), KC_G, HM_RSFT)
COMB(CMB_GRAVE_E, ACCENT_COMBO(2, 1), KC_G, HM_RCTL)
COMB(CMB_GRAVE_I, ACCENT_COMBO(2, 2), KC_G, HM_RGUI)
COMB(CMB_GRAVE_O, ACCENT_COMBO(2, 3), KC_G, HM_RALT)
COMB(CMB_GRAVE_U, ACCENT_COMBO(2, 4), KC_G, KC_U)
COMB(CMB_GRAVE_Y, ACCENT_COMBO(2, 5), KC_G, KC_Y)
COMB(CMB_GRAVE_AE, ACCENT_COMBO(2, 6), KC_G, DK_AE)
COMB(CMB_GRAVE_OE, ACCENT_COMBO(2, 7), KC_G, DK_OE)
COMB(CMB_GRAVE_AA, ACCENT_COMBO(2, 8), KC_G, DK_AA)

// ACUTE (´) + vowels
COMB(CMB_ACUTE_A, ACCENT_COMBO(3, 0), KC_M, HM_RSFT)
COMB(CMB_ACUTE_E, ACCENT_COMBO(3, 1), KC_M, HM_RCTL)
COMB(CMB_ACUTE_I, ACCENT_COMBO(3, 2), KC_M, HM_RGUI)
COMB(CMB_ACUTE_O, ACCENT_COMBO(3, 3), KC_M, HM_RALT)
COMB(CMB_ACUTE_U, ACCENT_COMBO(3, 4), KC_M, KC_U)
COMB(CMB_ACUTE_Y, ACCENT_COMBO(3, 5), KC_M, KC_Y)
COMB(CMB_ACUTE_AE, ACCENT_COMBO(3, 6), KC_M, DK_AE)
COMB(CMB_ACUTE_OE, ACCENT_COMBO(3, 7), KC_M, DK_OE)
COMB(CMB_ACUTE_AA, ACCENT_COMBO(3, 8), KC_M, DK_AA)

// TILDE (~) + vowels
COMB(CMB_TILDE_A, ACCENT_COMBO(4, 0), KC_J, HM_RSFT)
COMB(CMB_TILDE_E, ACCENT_COMBO(4, 1), KC_J, HM_RCTL)
COMB(CMB_TILDE_I, ACCENT_COMBO(4, 2), KC_J, HM_RGUI)
COMB(CMB_TILDE_O, ACCENT_COMBO(4, 3), KC_J, HM_RALT)
COMB(CMB_TILDE_U, ACCENT_COMBO(4, 4), KC_J, KC_U)
COMB(CMB_TILDE_Y, ACCENT_COMBO(4, 5), KC_J, KC_Y)
COMB(CMB_TILDE_AE, ACCENT_COMBO(4, 6), KC_J, DK_AE)
COMB(CMB_TILDE_OE, ACCENT_COMBO(4, 7), KC_J, DK_OE)
COMB(CMB_TILDE_AA, ACCENT_COMBO(4, 8), KC_J, DK_AA)
